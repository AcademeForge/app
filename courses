<!DOCTYPE html>
<html lang="en">
<head>
<script>
(function(){
  var dark = localStorage.getItem('af_dark_mode') === '1';
  document.documentElement.setAttribute('data-theme', dark ? 'dark' : 'light');
})();
</script>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover"/>
<meta name="theme-color" content="#4f46e5"/>
<meta name="mobile-web-app-capable" content="yes"/>
<title>Explore — AcademeForge</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link rel="icon" type="image/jpeg" href="/IMG/AF%20LOGO%202.jpeg">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Sora:wght@700;800;900&display=swap" rel="stylesheet"/>
<style>
/* ── TOKENS (matched 1:1 to main app) ── */
:root {
  --p:#4f46e5; --p2:#3730a3; --pl:#818cf8; --p-soft:rgba(79,70,229,.10);
  --acc:#06b6d4; --acc2:#f59e0b;
  --err:#ef4444; --ok:#22c55e;
  --bg:#f0f2ff; --shell:#fff;
  --card:rgba(255,255,255,.85); --card-s:#fff;
  --nav:rgba(255,255,255,.94); --hdr:rgba(255,255,255,.97);
  --inp:#f4f5fb; --grp:rgba(79,70,229,.06);
  --t1:#0f0e2a; --t2:#4b5563; --tm:#9ca3af;
  --b1:rgba(79,70,229,.12); --bc:rgba(79,70,229,.18);
  --sh:0 2px 12px rgba(79,70,229,.08),0 1px 3px rgba(0,0,0,.04);
  --she:0 8px 32px rgba(79,70,229,.14);
  --shell-border:#c7cbea;
  --nav-h:62px;
  --fd:'Sora',sans-serif;
  --fb:'Inter',sans-serif;
}
[data-theme="dark"] {
  --bg:#0c0b1d; --shell:#120f2a;
  --card:rgba(30,27,60,.82); --card-s:#1e1b3c;
  --nav:rgba(18,15,42,.97); --hdr:rgba(18,15,42,.98);
  --inp:#1e1b3c; --grp:rgba(129,140,248,.08);
  --t1:#f0eeff; --t2:#a5a3c2; --tm:#6b6a8a;
  --b1:rgba(129,140,248,.14); --bc:rgba(129,140,248,.22);
  --sh:0 2px 12px rgba(0,0,0,.32); --she:0 8px 32px rgba(0,0,0,.44);
  --shell-border:#202637;
  --p-soft:rgba(129,140,248,.12);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html{font-size:15px;-webkit-text-size-adjust:100%}
html,body{height:100%;min-height:100dvh}
body{
  font-family:var(--fb); background:var(--bg); color:var(--t1);
  -webkit-font-smoothing:antialiased;
  display:flex;align-items:center;justify-content:center;
  overflow:hidden;height:100dvh;
}
[data-theme="light"]{color-scheme:light}
[data-theme="dark"]{color-scheme:dark}
button{font-family:var(--fb);cursor:pointer;border:none;background:none;color:inherit}
a{text-decoration:none;color:inherit}
img{display:block;max-width:100%}
ul{list-style:none}
*,body,html{-webkit-user-select:none;-moz-user-select:none;user-select:none}
input,textarea{-webkit-user-select:text;-moz-user-select:text;user-select:text}

.af-shell{ width:min(100%,460px); height:100dvh; background:var(--shell); position:relative; display:flex; flex-direction:column; overflow:hidden; }
@media(min-width:520px){
  body{background:var(--bg)}
  .af-shell{ height:min(900px,calc(100dvh - 32px)); border:8px solid var(--shell-border); border-radius:44px; box-shadow:0 30px 90px rgba(0,0,0,.28); }
  [data-theme="dark"] .af-shell{ box-shadow:0 30px 90px rgba(0,0,0,.75); }
}

/* ── TOPBAR ── */
.af-topbar{
  flex-shrink:0;height:52px;background:var(--hdr);
  backdrop-filter:blur(16px) saturate(160%);-webkit-backdrop-filter:blur(16px) saturate(160%);
  border-bottom:1px solid var(--b1);
  display:flex;align-items:center;padding:0 14px;gap:10px;z-index:100;
}
.af-back{
  width:34px;height:34px;border-radius:10px;background:var(--grp);
  border:1px solid var(--b1);color:var(--t1);font-size:17px;
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
}
.af-back:active{opacity:.7}
.af-topbar-title{font-family:var(--fd);font-size:14.5px;font-weight:800;color:var(--t1);flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.af-help{width:30px;height:30px;border-radius:50%;background:var(--t1);color:var(--shell);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:800;flex-shrink:0}
.af-toc-btn{width:34px;height:34px;border-radius:10px;background:var(--grp);border:1px solid var(--b1);display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0}

/* ── PAGES / VIEW SWITCH ── */
.af-view{ display:none; flex:1; min-height:0; flex-direction:column; overflow:hidden; }
.af-view.active{ display:flex; }
.af-page{
  flex:1;overflow-y:scroll;overflow-x:hidden;-webkit-overflow-scrolling:touch;
  overscroll-behavior-y:contain; min-height:0;
  padding-bottom:calc(var(--nav-h) + 20px + env(safe-area-inset-bottom,0px));
}
.af-page.no-nav-pad{ padding-bottom:24px; }
.af-page::-webkit-scrollbar{width:2px}
.af-page::-webkit-scrollbar-thumb{background:var(--bc);border-radius:99px}

/* ── EXPLORE: FILTER BAR ── */
.af-body{padding:14px;display:flex;flex-direction:column;gap:14px}
.af-filter-wrap{position:relative}
.af-filter-btn{
  width:100%;height:48px;border-radius:14px;border:1.5px solid var(--b1);
  background:var(--inp);color:var(--t1);font-size:14px;font-weight:600;
  display:flex;align-items:center;justify-content:space-between;padding:0 16px;
}
.af-filter-btn span.chev{color:var(--tm);font-size:12px;transition:transform .2s}
.af-filter-btn.open span.chev{transform:rotate(180deg)}
.af-filter-menu{
  position:absolute;top:54px;left:0;right:0;z-index:50;
  background:var(--card-s);border:1.5px solid var(--b1);border-radius:14px;
  box-shadow:var(--she);max-height:280px;overflow-y:auto;display:none;
}
.af-filter-menu.open{display:block}
.af-filter-opt{padding:13px 16px;font-size:14px;font-weight:600;color:var(--t1);border-bottom:1px solid var(--b1)}
.af-filter-opt:last-child{border-bottom:none}
.af-filter-opt.sel{background:var(--p-soft);color:var(--p)}
.af-filter-opt:active{background:var(--grp)}

/* Tabs (Newest / Most popular) */
.af-tabs{display:flex;flex-direction:column;gap:8px}
.af-tabs-row{display:flex}
.af-tab-btn{flex:1;text-align:center;font-size:13px;font-weight:700;color:var(--tm);padding-bottom:8px}
.af-tab-btn.active{color:var(--t1)}
.af-tabs-track{height:3px;background:var(--b1);border-radius:99px;display:flex;overflow:hidden}
.af-tabs-indicator{height:100%;width:50%;background:linear-gradient(90deg,var(--p),var(--acc));border-radius:99px;transition:transform .25s ease}

/* Course cards */
.af-course-card{
  border-radius:16px;overflow:hidden;background:var(--card-s);
  border:1.5px solid var(--bc);box-shadow:var(--sh);width:100%;text-align:left;
}
.af-course-card:active{opacity:.92}
.af-course-img{width:100%;aspect-ratio:16/10;object-fit:cover;background:var(--grp)}
.af-course-body{padding:13px 14px 15px;display:flex;flex-direction:column;gap:6px}
.af-course-cat{font-size:10.5px;font-weight:700;letter-spacing:.05em;text-transform:uppercase;color:var(--tm)}
.af-course-title{font-family:var(--fd);font-size:16px;font-weight:800;color:var(--t1);line-height:1.25}
.af-course-pills{display:flex;gap:7px;margin-top:4px;flex-wrap:wrap}
.af-pill{font-size:10.5px;font-weight:700;padding:4px 10px;border-radius:99px}
.af-pill-done{background:rgba(34,197,94,.14);color:#15803d}
[data-theme="dark"] .af-pill-done{color:#4ade80}
.af-pill-progress{background:rgba(245,158,11,.14);color:#b45309}
[data-theme="dark"] .af-pill-progress{color:#fbbf24}
.af-pill-offline{background:var(--grp);color:var(--t2);display:flex;align-items:center;gap:4px}

.af-empty{padding:40px 20px;text-align:center;color:var(--tm);font-size:13px;display:flex;flex-direction:column;align-items:center;gap:10px}
.af-empty span{font-size:30px}

/* ── COURSE DETAIL ── */
.af-detail-hero{width:100%;aspect-ratio:16/9;object-fit:cover;flex-shrink:0}
.af-detail-body{padding:18px 18px 28px;display:flex;flex-direction:column;gap:14px}
.af-detail-cat{font-size:11px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--pl)}
.af-detail-title{font-family:var(--fd);font-size:23px;font-weight:900;color:var(--t1);line-height:1.15;letter-spacing:-.02em}
.af-detail-sub{font-size:13.5px;color:var(--t2);line-height:1.6}
.af-meta-list{display:flex;flex-direction:column;gap:7px;padding:13px 14px;background:var(--grp);border:1px solid var(--b1);border-radius:13px}
.af-meta-item{display:flex;align-items:center;gap:8px;font-size:12.5px;color:var(--t2);font-weight:600}
.af-meta-item span.ic{font-size:14px}
.af-btn-primary{
  width:100%;height:52px;border-radius:14px;border:none;
  background:linear-gradient(135deg,var(--p) 0%,var(--p2) 100%);
  color:#fff;font-size:15px;font-weight:700;box-shadow:0 4px 16px rgba(79,70,229,.35);
}
.af-btn-primary:active{transform:scale(.98);opacity:.9}
.af-progress-wrap{display:flex;flex-direction:column;gap:6px}
.af-progress-track{height:7px;background:var(--b1);border-radius:99px;overflow:hidden}
.af-progress-fill{height:100%;background:linear-gradient(90deg,var(--p),var(--acc));border-radius:99px;transition:width .3s ease}
.af-progress-label{font-size:11.5px;color:var(--tm);font-weight:600;display:flex;justify-content:space-between}
.af-detail-desc{font-size:13.5px;color:var(--t2);line-height:1.75}
.af-section-h{font-family:var(--fd);font-size:15px;font-weight:800;color:var(--t1);margin-top:4px}

/* ── MODULE LIST ── */
.af-mod-head{padding:16px 18px 6px;display:flex;flex-direction:column;gap:10px;flex-shrink:0}
.af-mod-progress-top{height:5px;background:var(--b1);border-radius:99px;overflow:hidden}
.af-mod-progress-fill{height:100%;background:linear-gradient(90deg,var(--p),var(--acc));border-radius:99px;transition:width .3s ease}
.af-mod-progress-text{font-size:11.5px;color:var(--tm);font-weight:700;text-align:right}
.af-mod-course-card{display:flex;gap:12px;align-items:center;padding:12px 0}
.af-mod-course-thumb{width:56px;height:56px;border-radius:12px;object-fit:cover;flex-shrink:0;background:var(--grp)}
.af-mod-course-title{font-family:var(--fd);font-size:15px;font-weight:800;color:var(--t1);line-height:1.25}
.af-mod-count{font-size:11px;font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:var(--tm);padding:10px 0 6px;border-top:1px solid var(--b1);margin-top:4px}
.af-mod-list{padding:0 18px 24px;display:flex;flex-direction:column}
.af-mod-row{display:flex;align-items:flex-start;gap:12px;padding:13px 0;border-bottom:1px solid var(--b1);width:100%;text-align:left}
.af-mod-row:last-child{border-bottom:none}
.af-mod-radio{
  width:21px;height:21px;border-radius:50%;border:2px solid var(--bc);flex-shrink:0;margin-top:1px;
  display:flex;align-items:center;justify-content:center;
}
.af-mod-radio.done{background:var(--ok);border-color:var(--ok)}
.af-mod-radio.done::after{content:'✓';color:#fff;font-size:11px;font-weight:900}
.af-mod-icon{font-size:15px;color:var(--tm);flex-shrink:0;margin-top:1px;width:18px;text-align:center}
.af-mod-row-title{font-size:14px;font-weight:600;color:var(--t1);line-height:1.4;flex:1}
.af-mod-row.locked .af-mod-row-title{color:var(--tm)}
.af-mod-optional{font-size:10px;font-weight:700;color:var(--tm);background:var(--grp);padding:2px 8px;border-radius:99px;margin-left:6px;flex-shrink:0}

/* ── LESSON PLAYER ── */
.af-lesson-progress-bar{height:4px;background:var(--b1);flex-shrink:0}
.af-lesson-progress-fill{height:100%;background:var(--p);transition:width .3s ease}
.af-lesson-progress-row{display:flex;align-items:center;gap:10px;padding:10px 16px;flex-shrink:0}
.af-lesson-progress-track{flex:1;height:5px;background:var(--b1);border-radius:99px;overflow:hidden}
.af-lesson-progress-fill2{height:100%;background:linear-gradient(90deg,var(--p),var(--acc));border-radius:99px;transition:width .3s ease}
.af-lesson-progress-pct{font-size:11.5px;font-weight:700;color:var(--tm);flex-shrink:0}
.af-close-x{width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:17px;color:var(--t1);flex-shrink:0}

.af-lesson-banner{width:100%;aspect-ratio:16/8;object-fit:cover;flex-shrink:0}
.af-lesson-body{padding:20px 18px 12px;display:flex;flex-direction:column;gap:16px}
.af-block-heading{font-family:var(--fd);font-size:20px;font-weight:800;color:var(--t1);line-height:1.25}
.af-block-paragraph{font-size:14px;color:var(--t2);line-height:1.8}
.af-block-callout{
  background:var(--p-soft);border:1.5px solid var(--bc);border-radius:13px;
  padding:14px 15px;font-size:13.5px;color:var(--t1);line-height:1.65;font-weight:500;
}
.af-block-image{width:100%;border-radius:13px;object-fit:cover;max-height:220px}
.af-block-list{display:flex;flex-direction:column;gap:9px;padding-left:2px}
.af-block-list-item{display:flex;gap:10px;font-size:13.5px;color:var(--t2);line-height:1.6}
.af-block-list-item::before{content:'';width:6px;height:6px;border-radius:50%;background:var(--p);flex-shrink:0;margin-top:7px}

/* ── CHECK WIDGET ── */
.af-check-card{
  margin:6px 18px 0;padding:18px 16px;border-radius:16px;
  background:linear-gradient(160deg,var(--p-soft),transparent);
  border:1.5px solid var(--bc);display:flex;flex-direction:column;gap:14px;
}
.af-check-title{font-size:13px;font-weight:700;color:var(--t1)}
.af-check-equation{
  font-family:var(--fd);font-size:26px;font-weight:800;color:var(--t1);
  display:flex;align-items:center;justify-content:center;gap:10px;
}
.af-check-input{
  width:74px;height:54px;border-radius:13px;border:2px solid var(--bc);
  background:var(--inp);text-align:center;font-size:22px;font-weight:800;
  color:var(--t1);font-family:var(--fd);outline:none;
}
.af-check-input:focus{border-color:var(--p)}
.af-check-input.wrong{border-color:var(--err);animation:shake .3s}
.af-check-input.right{border-color:var(--ok)}
@keyframes shake{0%,100%{transform:translateX(0)}25%{transform:translateX(-5px)}75%{transform:translateX(5px)}}
.af-check-btn{
  height:44px;border-radius:12px;background:var(--t1);color:var(--shell);
  font-size:13.5px;font-weight:700;
}
.af-check-btn:active{opacity:.85}
.af-check-msg{font-size:12.5px;font-weight:600;text-align:center;min-height:16px}
.af-check-msg.err{color:var(--err)}
.af-check-msg.ok{color:var(--ok)}
.af-check-done-badge{
  display:flex;align-items:center;justify-content:center;gap:8px;
  font-size:13px;font-weight:700;color:var(--ok);padding:6px 0;
}

.af-lesson-footer{padding:18px 18px 26px;flex-shrink:0}
.af-btn-continue{
  width:100%;height:52px;border-radius:14px;border:none;
  background:linear-gradient(135deg,var(--p) 0%,var(--p2) 100%);
  color:#fff;font-size:15px;font-weight:700;box-shadow:0 4px 16px rgba(79,70,229,.35);
  transition:opacity .2s,transform .2s;
}
.af-btn-continue:active{transform:scale(.98)}
.af-btn-continue:disabled{opacity:.4;pointer-events:none}
.af-btn-continue.ready{animation:pulseGlow 1.6s ease infinite}
@keyframes pulseGlow{0%,100%{box-shadow:0 4px 16px rgba(79,70,229,.35)}50%{box-shadow:0 4px 24px rgba(79,70,229,.6)}}
.af-lock-hint{text-align:center;font-size:11.5px;color:var(--tm);margin-top:8px;font-weight:600}

/* Completion screen */
.af-complete-wrap{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;padding:30px;text-align:center}
.af-complete-badge{width:84px;height:84px;border-radius:50%;background:linear-gradient(135deg,var(--p),var(--acc));display:flex;align-items:center;justify-content:center;font-size:38px;box-shadow:0 10px 30px rgba(79,70,229,.35)}
.af-complete-title{font-family:var(--fd);font-size:21px;font-weight:900;color:var(--t1)}
.af-complete-sub{font-size:13.5px;color:var(--t2);line-height:1.6}

/* ── BOTTOM NAV (shared) ── */
.af-bnav{
  position:absolute;bottom:0;left:0;right:0;z-index:999;height:var(--nav-h);
  background:var(--nav);border-top:1px solid var(--b1);
  display:flex;align-items:center;padding:0 4px;padding-bottom:env(safe-area-inset-bottom,0px);
}
.af-nav-btn{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;height:100%;border-radius:10px;padding:6px 4px;position:relative}
.af-nav-btn::before{content:'';position:absolute;top:6px;left:50%;transform:translateX(-50%);width:0;height:2px;background:var(--p);border-radius:99px;transition:width .15s ease}
.af-nav-btn.active::before{width:22px}
.af-nav-icon{font-size:19px;line-height:1}
.af-nav-label{font-size:9.5px;font-weight:700;color:var(--tm)}
.af-nav-btn.active .af-nav-label{color:var(--p)}

/* Loading skeleton */
.af-skel{background:linear-gradient(90deg,var(--grp) 25%,var(--b1) 50%,var(--grp) 75%);background-size:200% 100%;animation:skel 1.4s ease infinite;border-radius:14px}
@keyframes skel{0%{background-position:200% 0}100%{background-position:-200% 0}}
.af-skel-card{height:210px;margin-bottom:14px}

/* Toast */
.af-toast-wrap{position:absolute;bottom:calc(var(--nav-h) + 14px);left:14px;right:14px;z-index:99999;pointer-events:none}
.af-toast{display:flex;align-items:flex-start;gap:12px;background:var(--card-s);color:var(--t1);border:1px solid var(--bc);border-radius:13px;padding:11px 13px;box-shadow:var(--she);pointer-events:auto}
.af-toast-ok{border-left:4px solid #22c55e}
.af-toast-err{border-left:4px solid #ef4444}
.af-toast-title{font-size:12px;font-weight:700;margin:0 0 2px}
.af-toast-msg{font-size:11.5px;margin:0;line-height:1.4}
</style>
</head>
<body>

<div class="af-shell" id="afShell">

  <!-- ════════ VIEW: EXPLORE CATALOG ════════ -->
  <div class="af-view active" id="viewCatalog">
    <header class="af-topbar">
      <div class="af-topbar-title" style="display:flex;align-items:center;gap:8px">
        <span style="font-family:var(--fd);font-weight:900;font-size:15px">Explore</span>
      </div>
      <button class="af-toc-btn" onclick="toggleDark()" aria-label="Theme" id="darkToggleBtn">🌙</button>
    </header>

    <div class="af-page" id="catalogPage">
      <div class="af-body">
        <div class="af-filter-wrap">
          <button class="af-filter-btn" id="filterBtn" onclick="toggleFilterMenu()">
            <span id="filterLabel">All Courses</span><span class="chev">▾</span>
          </button>
          <div class="af-filter-menu" id="filterMenu"></div>
        </div>

        <div class="af-tabs">
          <div class="af-tabs-row">
            <button class="af-tab-btn active" id="tabNewest" onclick="setSort('newest')">Newest</button>
            <button class="af-tab-btn" id="tabPopular" onclick="setSort('popular')">Most popular</button>
          </div>
          <div class="af-tabs-track"><div class="af-tabs-indicator" id="tabsIndicator"></div></div>
        </div>

        <div id="courseList" style="display:flex;flex-direction:column;gap:13px">
          <div class="af-skel af-skel-card"></div>
          <div class="af-skel af-skel-card"></div>
        </div>
      </div>
    </div>

    <nav class="af-bnav">
      <button class="af-nav-btn" onclick="window.location.href='/index.html'" type="button">
        <span class="af-nav-icon">🏠</span><span class="af-nav-label">Home</span>
      </button>
      <button class="af-nav-btn active" type="button">
        <span class="af-nav-icon">🧭</span><span class="af-nav-label">Explore</span>
      </button>
      <button class="af-nav-btn" onclick="window.location.href='/batches/index.html'" type="button">
        <span class="af-nav-icon">📚</span><span class="af-nav-label">Batches</span>
      </button>
      <button class="af-nav-btn" onclick="window.location.href='/community/indix.html'" type="button">
        <span class="af-nav-icon">💬</span><span class="af-nav-label">Community</span>
      </button>
      <button class="af-nav-btn" onclick="window.location.href='/setting/index.html'" type="button">
        <span class="af-nav-icon">⚙️</span><span class="af-nav-label">Settings</span>
      </button>
    </nav>
  </div>

  <!-- ════════ VIEW: COURSE DETAIL ════════ -->
  <div class="af-view" id="viewDetail">
    <header class="af-topbar">
      <button class="af-back" onclick="goToCatalog()">←</button>
      <div class="af-topbar-title" id="detailTopTitle">Course</div>
    </header>
    <div class="af-page no-nav-pad" id="detailPage"></div>
  </div>

  <!-- ════════ VIEW: MODULE LIST ════════ -->
  <div class="af-view" id="viewModules">
    <header class="af-topbar">
      <button class="af-back" onclick="closeModuleList()">✕</button>
      <div class="af-topbar-title">Course content</div>
    </header>
    <div class="af-page no-nav-pad" id="modulesPage"></div>
  </div>

  <!-- ════════ VIEW: LESSON PLAYER ════════ -->
  <div class="af-view" id="viewLesson">
    <header class="af-topbar">
      <button class="af-back" onclick="backFromLesson()">←</button>
      <span class="af-help">?</span>
      <div class="af-topbar-title" style="text-align:right">Lesson</div>
      <button class="af-toc-btn" onclick="openModuleListFromLesson()">☰</button>
    </header>
    <div class="af-lesson-progress-row">
      <button class="af-close-x" onclick="backFromLesson()" aria-label="Close" style="display:none"></button>
      <div class="af-lesson-progress-track"><div class="af-lesson-progress-fill2" id="lessonProgFill" style="width:0%"></div></div>
      <span class="af-lesson-progress-pct" id="lessonProgPct">Progress: 0%</span>
    </div>
    <div class="af-page no-nav-pad" id="lessonPage"></div>
  </div>

</div><!-- /af-shell -->

<div class="af-toast-wrap" id="afToastWrap"></div>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script>
'use strict';

/* ── CONFIG ── */
const STUDENT_URL = "https://afooyyydhlwngzssgqih.supabase.co";
const STUDENT_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImFmb295eXlkaGx3bmd6c3NncWloIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzg2NDQxMjgsImV4cCI6MjA5NDIyMDEyOH0.KG0XO0oP_2MpewHoIwTtbrKg5FkyOYRUtVzLH1MSJiE";
const CATALOG_EDGE = STUDENT_URL + "/functions/v1/course-catalog-af";
const HDRS = {'Content-Type':'application/json','apikey':STUDENT_KEY,'Authorization':'Bearer '+STUDENT_KEY};

const $ = id => document.getElementById(id);

function getStudentId(){ return localStorage.getItem('af_student_uuid') || null; }

async function callCatalog(action, payload){
  try{
    const res = await fetch(CATALOG_EDGE, {method:'POST', headers:HDRS, body:JSON.stringify({action, ...payload})});
    const data = await res.json();
    return data;
  }catch(e){
    return {ok:false, message:'Network error. Please check your connection.'};
  }
}

/* ── TOAST ── */
function afToast(msg, type){
  const wrap = $('afToastWrap'); wrap.innerHTML='';
  const t = document.createElement('div');
  t.className = 'af-toast af-toast-' + (type||'ok');
  t.innerHTML = '<div><p class="af-toast-title">'+(type==='err'?'Notice':'Done')+'</p><p class="af-toast-msg">'+msg+'</p></div>';
  wrap.appendChild(t);
  setTimeout(()=>t.remove(), 2600);
}

/* ── DARK MODE ── */
function toggleDark(){
  const isDark = document.documentElement.getAttribute('data-theme')==='dark';
  document.documentElement.setAttribute('data-theme', isDark?'light':'dark');
  localStorage.setItem('af_dark_mode', isDark?'0':'1');
  $('darkToggleBtn').textContent = isDark?'🌙':'☀️';
}
if(localStorage.getItem('af_dark_mode')==='1') $('darkToggleBtn').textContent='☀️';

/* ── VIEW SWITCHING ── */
function showView(id){
  document.querySelectorAll('.af-view').forEach(v=>v.classList.remove('active'));
  $(id).classList.add('active');
}

/* ════════════════════════════════════════
   CATALOG
   ════════════════════════════════════════ */
let _categories = ['All Courses'];
let _selectedCategory = 'All Courses';
let _sortMode = 'newest'; // newest | popular
let _allCourses = [];

function toggleFilterMenu(){
  $('filterMenu').classList.toggle('open');
  $('filterBtn').classList.toggle('open');
}

function renderFilterMenu(){
  const menu = $('filterMenu');
  menu.innerHTML = _categories.map(c =>
    `<div class="af-filter-opt ${c===_selectedCategory?'sel':''}" onclick="selectCategory('${c.replace(/'/g,"\\'")}')">${c}</div>`
  ).join('');
}

function selectCategory(cat){
  _selectedCategory = cat;
  $('filterLabel').textContent = cat;
  toggleFilterMenu();
  loadCourses();
}
window.selectCategory = selectCategory;

function setSort(mode){
  _sortMode = mode;
  $('tabNewest').classList.toggle('active', mode==='newest');
  $('tabPopular').classList.toggle('active', mode==='popular');
  $('tabsIndicator').style.transform = mode==='newest' ? 'translateX(0%)' : 'translateX(100%)';
  renderCourseList();
}
window.setSort = setSort;

async function loadCourses(){
  $('courseList').innerHTML = '<div class="af-skel af-skel-card"></div><div class="af-skel af-skel-card"></div>';
  const data = await callCatalog('list_courses', {
    category: _selectedCategory,
    student_id: getStudentId()
  });
  if(!data.ok){
    $('courseList').innerHTML = `<div class="af-empty"><span>⚠️</span>${escapeHtml(data.message||'Could not load courses.')}</div>`;
    return;
  }
  _categories = ['All Courses', ...(data.categories||[])];
  renderFilterMenu();
  _allCourses = data.courses || [];
  renderCourseList();
}

function renderCourseList(){
  let list = [..._allCourses];
  if(_sortMode === 'newest'){
    list.sort((a,b)=> new Date(b.created_at) - new Date(a.created_at));
  } else {
    // "most popular" proxy: completed first, then in_progress, then rest, then by sort_order
    const rank = s => s==='completed'?0:s==='in_progress'?1:2;
    list.sort((a,b)=> rank(a.status)-rank(b.status) || a.sort_order-b.sort_order);
  }

  if(list.length===0){
    $('courseList').innerHTML = `<div class="af-empty"><span>📭</span>No courses in this category yet.</div>`;
    return;
  }

  $('courseList').innerHTML = list.map(c => `
    <button class="af-course-card" onclick="openCourse('${c.id}')">
      <img class="af-course-img" src="${c.cover_image_url||fallbackImg()}" alt="${escapeHtml(c.title)}" loading="lazy"/>
      <div class="af-course-body">
        <div class="af-course-cat">${escapeHtml(c.category)}</div>
        <div class="af-course-title">${escapeHtml(c.title)}</div>
        <div class="af-course-pills">
          ${c.status==='completed' ? '<span class="af-pill af-pill-done">Completed</span>' : ''}
          ${c.status==='in_progress' ? '<span class="af-pill af-pill-progress">In progress · '+c.percent+'%</span>' : ''}
          <span class="af-pill af-pill-offline">☁ Available offline</span>
        </div>
      </div>
    </button>
  `).join('');
}

function fallbackImg(){ return 'https://images.unsplash.com/photo-1501504905252-473c47e087f8?w=800&q=80'; }
function escapeHtml(s){ return String(s||'').replace(/[&<>"']/g, m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m])); }

function goToCatalog(){ showView('viewCatalog'); }
window.goToCatalog = goToCatalog;

/* ════════════════════════════════════════
   COURSE DETAIL
   ════════════════════════════════════════ */
let _currentCourse = null;
let _currentModules = [];

async function openCourse(courseId){
  showView('viewDetail');
  $('detailPage').innerHTML = `<div style="padding:14px"><div class="af-skel" style="aspect-ratio:16/9;margin-bottom:16px"></div><div class="af-skel" style="height:18px;width:60%;margin-bottom:10px"></div><div class="af-skel" style="height:28px;width:90%;margin-bottom:16px"></div></div>`;

  const data = await callCatalog('get_course', { course_id: courseId, student_id: getStudentId() });
  if(!data.ok){
    $('detailPage').innerHTML = `<div class="af-empty"><span>⚠️</span>${escapeHtml(data.message||'Could not load this course.')}</div>`;
    return;
  }
  _currentCourse = data.course;
  _currentModules = data.modules || [];
  const progress = data.progress;

  $('detailTopTitle').textContent = _currentCourse.title;

  const percent = progress?.percent || 0;
  const isStarted = !!progress;

  $('detailPage').innerHTML = `
    <img class="af-detail-hero" src="${_currentCourse.banner_image_url || _currentCourse.cover_image_url || fallbackImg()}" alt=""/>
    <div class="af-detail-body">
      <div class="af-detail-cat">${escapeHtml(_currentCourse.category)}</div>
      <h1 class="af-detail-title">${escapeHtml(_currentCourse.title)}</h1>
      ${_currentCourse.subtitle ? `<p class="af-detail-sub">${escapeHtml(_currentCourse.subtitle)}</p>` : ''}

      <div class="af-meta-list">
        ${_currentCourse.has_certificate ? `<div class="af-meta-item"><span class="ic">🎓</span> Certificate available on completion</div>` : ''}
        <div class="af-meta-item"><span class="ic">⏱</span> Duration: No more than ${_currentCourse.duration_minutes} minutes</div>
        <div class="af-meta-item"><span class="ic">📍</span> Pace: ${escapeHtml(_currentCourse.pace)}</div>
      </div>

      ${isStarted ? `
        <div class="af-progress-wrap">
          <div class="af-progress-track"><div class="af-progress-fill" style="width:${percent}%"></div></div>
          <div class="af-progress-label"><span>${percent}% complete</span><span>${progress.modules_done}/${progress.modules_total} modules</span></div>
        </div>
      ` : ''}

      <button class="af-btn-primary" onclick="enterModuleList()">${percent>0 && percent<100 ? 'Continue course' : percent>=100 ? 'Review course' : 'Start course'}</button>

      <div class="af-section-h">About this course</div>
      <p class="af-detail-desc">${escapeHtml(_currentCourse.description||'')}</p>
    </div>
  `;
}
window.openCourse = openCourse;

/* ════════════════════════════════════════
   MODULE LIST
   ════════════════════════════════════════ */
function enterModuleList(){
  showView('viewModules');
  renderModuleList();
}
window.enterModuleList = enterModuleList;

function closeModuleList(){ showView('viewDetail'); }
window.closeModuleList = closeModuleList;

const MOD_ICON = { lesson:'📄', survey:'📊', resource:'📄' };

function renderModuleList(){
  const total = _currentModules.length;
  const doneCount = _currentModules.filter(m=>m.is_done).length;
  const percent = total>0 ? Math.round((doneCount/total)*100) : 0;

  $('modulesPage').innerHTML = `
    <div class="af-mod-head">
      <div class="af-mod-progress-top"><div class="af-mod-progress-fill" style="width:${percent}%"></div></div>
      <div class="af-mod-progress-text">Progress: ${percent}%</div>
      <div class="af-mod-course-card">
        <img class="af-mod-course-thumb" src="${_currentCourse.cover_image_url||fallbackImg()}" alt=""/>
        <div class="af-mod-course-title">${escapeHtml(_currentCourse.title)}</div>
      </div>
      <div class="af-mod-count">Modules — ${doneCount}/${total}</div>
    </div>
    <div class="af-mod-list">
      ${_currentModules.map((m,i)=>{
        const locked = i>0 && !_currentModules[i-1].is_done && !m.is_done;
        return `
        <button class="af-mod-row ${locked?'locked':''}" onclick="${locked? '' : `openModule('${m.id}')`}">
          <div class="af-mod-radio ${m.is_done?'done':''}"></div>
          <span class="af-mod-icon">${MOD_ICON[m.module_type]||'📄'}</span>
          <span class="af-mod-row-title">${escapeHtml(m.title)}</span>
          ${m.is_optional ? '<span class="af-mod-optional">Optional</span>' : ''}
        </button>`;
      }).join('')}
    </div>
  `;
}

/* ════════════════════════════════════════
   LESSON PLAYER
   ════════════════════════════════════════ */
let _currentModule = null;
let _currentCheck = null;
let _checkPassed = false;
let _cameFromLesson = false;

async function openModule(moduleId){
  showView('viewLesson');
  $('lessonPage').innerHTML = `<div style="padding:20px"><div class="af-skel" style="aspect-ratio:16/8;margin-bottom:16px"></div><div class="af-skel" style="height:24px;width:70%;margin-bottom:10px"></div><div class="af-skel" style="height:80px"></div></div>`;
  $('lessonProgFill').style.width='0%'; $('lessonProgPct').textContent='Progress: 0%';

  const data = await callCatalog('get_module', { module_id: moduleId, student_id: getStudentId() });
  if(!data.ok){
    $('lessonPage').innerHTML = `<div class="af-empty"><span>⚠️</span>${escapeHtml(data.message||'Could not load this lesson.')}</div>`;
    return;
  }
  _currentModule = data.module;
  _currentCheck = data.check;
  _checkPassed = !!data.is_done; // if already done before, treat check as already passed
  _currentModule._next = data.next_module;

  const pct = data.module_total>0 ? Math.round(((data.module_index-1)/data.module_total)*100) : 0;
  $('lessonProgFill').style.width = pct+'%';
  $('lessonProgPct').textContent = 'Progress: '+pct+'%';

  renderLessonBlocks(data.blocks||[]);
}
window.openModule = openModule;

function renderLessonBlocks(blocks){
  let html = '';
  let bannerHtml = '';

  blocks.forEach(b=>{
    if(b.block_type==='banner'){
      bannerHtml = `<img class="af-lesson-banner" src="${b.content}" alt=""/>`;
    } else if(b.block_type==='heading'){
      html += `<div class="af-block-heading">${escapeHtml(b.content)}</div>`;
    } else if(b.block_type==='paragraph'){
      html += `<p class="af-block-paragraph">${escapeHtml(b.content)}</p>`;
    } else if(b.block_type==='callout'){
      html += `<div class="af-block-callout">${escapeHtml(b.content)}</div>`;
    } else if(b.block_type==='image'){
      html += `<img class="af-block-image" src="${b.content}" alt=""/>`;
    } else if(b.block_type==='list'){
      const items = b.list_items || [];
      html += `<div class="af-block-list">${items.map(it=>`<div class="af-block-list-item">${escapeHtml(it)}</div>`).join('')}</div>`;
    }
  });

  $('lessonPage').innerHTML = `
    ${bannerHtml}
    <div class="af-lesson-body">${html || '<p class="af-block-paragraph">No content yet for this lesson.</p>'}</div>
    <div id="checkSlot"></div>
    <div class="af-lesson-footer">
      <button class="af-btn-continue" id="continueBtn" ${_checkPassed?'':'disabled'} onclick="handleContinue()">Continue</button>
      <div class="af-lock-hint" id="lockHint" style="${_checkPassed?'display:none':''}">Solve the quick check above to unlock Continue</div>
    </div>
  `;

  renderCheckWidget();
}

function renderCheckWidget(){
  const slot = $('checkSlot');
  if(!_currentCheck || _checkPassed){
    if(_currentCheck && _checkPassed){
      slot.innerHTML = `<div class="af-check-card"><div class="af-check-done-badge"><span>✓</span> Quick check complete</div></div>`;
    } else {
      slot.innerHTML = '';
    }
    return;
  }
  const c = _currentCheck;
  slot.innerHTML = `
    <div class="af-check-card">
      <div class="af-check-title">${escapeHtml(c.prompt_text||'Quick check before you continue:')}</div>
      <div class="af-check-equation">
        <span>${c.operand_a}</span><span>${c.symbol}</span><span>${c.operand_b}</span><span>=</span>
        <input type="number" inputmode="numeric" class="af-check-input" id="checkInput" placeholder="?"/>
      </div>
      <button class="af-check-btn" onclick="submitCheck()">Check answer</button>
      <div class="af-check-msg" id="checkMsg"></div>
    </div>
  `;
  $('checkInput').addEventListener('keydown', e=>{ if(e.key==='Enter') submitCheck(); });
}

async function submitCheck(){
  const input = $('checkInput');
  const val = input.value;
  if(val===''){
    $('checkMsg').className='af-check-msg err'; $('checkMsg').textContent='Enter a number first.';
    return;
  }
  const data = await callCatalog('submit_check', { module_id: _currentModule.id, answer: val });
  if(!data.ok){
    $('checkMsg').className='af-check-msg err'; $('checkMsg').textContent='Could not check that. Try again.';
    return;
  }
  if(data.correct){
    input.classList.remove('wrong'); input.classList.add('right');
    $('checkMsg').className='af-check-msg ok'; $('checkMsg').textContent='Correct! Continue is unlocked.';
    _checkPassed = true;
    $('continueBtn').disabled = false;
    $('continueBtn').classList.add('ready');
    $('lockHint').style.display='none';
  } else {
    input.classList.remove('right'); input.classList.add('wrong');
    $('checkMsg').className='af-check-msg err'; $('checkMsg').textContent='Not quite — try again.';
  }
}
window.submitCheck = submitCheck;

async function handleContinue(){
  const sid = getStudentId();
  if(sid){
    await callCatalog('complete_module', { student_id: sid, module_id: _currentModule.id, course_id: _currentCourse.id });
    const idx = _currentModules.findIndex(m=>m.id===_currentModule.id);
    if(idx>=0) _currentModules[idx].is_done = true;
  } else {
    afToast('Log in to save your progress permanently.', 'err');
  }

  if(_currentModule._next){
    openModule(_currentModule._next.id);
  } else {
    showCompletionScreen();
  }
}
window.handleContinue = handleContinue;

function showCompletionScreen(){
  $('lessonPage').innerHTML = `
    <div class="af-complete-wrap">
      <div class="af-complete-badge">🎉</div>
      <div class="af-complete-title">Course complete!</div>
      <div class="af-complete-sub">You've finished every module in <strong>${escapeHtml(_currentCourse.title)}</strong>.${_currentCourse.has_certificate? ' Your certificate is ready in My Dashboard.':''}</div>
      <button class="af-btn-primary" style="margin-top:10px" onclick="finishToDetail()">Back to course</button>
    </div>
  `;
  $('lessonProgFill').style.width='100%'; $('lessonProgPct').textContent='Progress: 100%';
}

function finishToDetail(){
  openCourse(_currentCourse.id);
}
window.finishToDetail = finishToDetail;

function backFromLesson(){
  showView('viewModules');
  renderModuleList();
}
window.backFromLesson = backFromLesson;

function openModuleListFromLesson(){
  showView('viewModules');
  renderModuleList();
}
window.openModuleListFromLesson = openModuleListFromLesson;

/* INIT */
loadCourses();
</script>
</body>
</html>
